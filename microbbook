        { g:'B', d:'Fri Feb 13', t:'06:10', h:'Italy', a:'Slovakia', v:'R' },
        { g:'A', d:'Fri Feb 13', t:'10:40', h:'France', a:'Czechia', v:'R' },
        { g:'A', d:'Fri Feb 13', t:'15:10', h:'Canada', a:'Switzerland', v:'S' },
        { g:'B', d:'Sat Feb 14', t:'06:10', h:'Sweden', a:'Slovakia', v:'R' },
        { g:'C', d:'Sat Feb 14', t:'06:10', h:'Germany', a:'Latvia', v:'S' },
        { g:'B', d:'Sat Feb 14', t:'10:40', h:'Finland', a:'Italy', v:'R' },
        { g:'C', d:'Sat Feb 14', t:'15:10', h:'USA', a:'Denmark', v:'S' },
        { g:'A', d:'Sun Feb 15', t:'06:10', h:'Switzerland', a:'Czechia', v:'S' },
        { g:'A', d:'Sun Feb 15', t:'10:40', h:'Canada', a:'France', v:'R' },
        { g:'C', d:'Sun Feb 15', t:'13:10', h:'Denmark', a:'Latvia', v:'R' },
        { g:'C', d:'Sun Feb 15', t:'15:10', h:'USA', a:'Germany', v:'S' }
    ];

    const knockouts = [
        { header: 'QUALIFICATION ROUND' },
        { g:'Q', d:'Tue Feb 17', t:'06:10', h:'Seed 8', a:'Seed 9', v:'R' },
        { g:'Q', d:'Tue Feb 17', t:'10:40', h:'Seed 5', a:'Seed 12', v:'S' },
        { g:'Q', d:'Tue Feb 17', t:'12:10', h:'Seed 6', a:'Seed 11', v:'R' },
        { g:'Q', d:'Tue Feb 17', t:'15:10', h:'Seed 7', a:'Seed 10', v:'S' },
        { header: 'QUARTERFINALS' },
        { g:'QF', d:'Wed Feb 18', t:'10:40', h:'Seed 1', a:'Reseed 4', v:'S' },
        { g:'QF', d:'Wed Feb 18', t:'10:40', h:'Seed 2', a:'Reseed 3', v:'R' },
        { g:'QF', d:'Wed Feb 18', t:'15:10', h:'Seed 3', a:'Reseed 2', v:'S' },
        { g:'QF', d:'Wed Feb 18', t:'15:10', h:'Seed 4', a:'Reseed 1', v:'R' },
        { header: 'SEMIFINALS' },
        { g:'SF', d:'Fri Feb 20', t:'10:40', h:'Win QF', a:'Win QF', v:'S' },
        { g:'SF', d:'Fri Feb 20', t:'15:10', h:'Win QF', a:'Win QF', v:'S' },
        { header: 'MEDAL GAMES' },
        { g:'🥉', d:'Sat Feb 21', t:'14:40', h:'Lose SF1', a:'Lose SF2', v:'S' },
        { g:'🥇', d:'Sun Feb 22', t:'08:10', h:'Win SF1', a:'Win SF2', v:'S' }
    ];

    function render(games, targetId) {
        const target = document.getElementById(targetId);
        const isPrelims = targetId === 'sched-prelims';
        
        // Exact calibration:
        // Prelims: 18 rows + header + footer. 
        // Reduced padding significantly to prevent bottom cutoff.
        const rowPadding = isPrelims ? 1.4 : 3.4; 

        games.forEach(g => {
            if (g.header) {
                const tr = document.createElement('tr');
                tr.innerHTML = `<td colspan="5" style="background:#f4f4f4; color:#333; font-weight:bold; text-align:center; font-size:5.5px; padding:1px; border-top:0.5pt solid #bbb; border-bottom:0.5pt solid #ddd;">${g.header}</td>`;
                target.appendChild(tr);
                return;
            }

            let [h, m] = g.t.split(':').map(Number);
            let ampm = h >= 12 ? 'p' : 'a';
            let showH = h % 12 || 12;
            let finalTime = `${showH}:${m.toString().padStart(2,'0')}${ampm}`;

            const tr = document.createElement('tr');
            if(g.g === 'A') tr.className = 'row-A';
            else if(g.g === 'B') tr.className = 'row-B';
            else if(g.g === 'C') tr.className = 'row-C';

            const flagH = getFlagImg(g.h);
            const flagA = getFlagImg(g.a);

            tr.innerHTML = `
                <td class="c-grp" style="padding:${rowPadding}px 0">${g.g}</td>
                <td class="c-date" style="padding:${rowPadding}px 0">${g.d}</td>
                <td class="c-ven" style="padding:${rowPadding}px 0">${g.v || 'S'}</td>
                <td class="c-time" style="padding:${rowPadding}px 0">${finalTime}</td>
                <td class="c-match" style="padding:${rowPadding}px 0">
                    <span class="team-home">${g.h} ${flagH}</span>
                    <div class="score-area">
                        <span class="sb"></span><span class="sb"></span>
                    </div>
                    <span class="team-away">${flagA} ${g.a}</span>
                </td>
            `;
            target.appendChild(tr);
        });
    }

    render(prelims, 'sched-prelims');
    render(knockouts, 'sched-ko');
</script>
