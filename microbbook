<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Men's Olympic Hockey 2026 - Micro Guide</title>
    <style>
        :root {
            /* Micro Sizing - 2.5in x 3in */
            --panel-width: 2.5in;
            --panel-height: 3in; 
            --header-bg: #1a1a1a;
            --header-text: #fff;
            --accent-red: #c0392b;
            --accent-blue: #2980b9;
            --accent-green: #27ae60;
            --font-base: 7px;
        }

        body {
            font-family: 'Arial Narrow', 'Roboto Condensed', sans-serif;
            background-color: #555;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* --- Print Grid --- */
        .print-container {
            width: 10.5in;
            background: white;
            padding: 0.2in;
            box-sizing: border-box;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-gap: 10px;
            justify-items: center;
        }

        /* --- Panel --- */
        .panel {
            width: var(--panel-width);
            height: var(--panel-height);
            border: 0.5pt solid #aaa;
            box-sizing: border-box;
            padding: 4px; 
            display: flex;
            flex-direction: column;
            background: #fff;
            overflow: hidden;
            position: relative;
        }
        
        /* --- Headers --- */
        h2 {
            margin: 0 0 2px 0;
            font-size: 8.5px;
            text-transform: uppercase;
            background: var(--header-bg);
            color: var(--header-text);
            padding: 2px 4px;
            font-weight: 900;
            display: flex; 
            justify-content: space-between;
            border-radius: 1px;
            letter-spacing: 0.3px;
            flex-shrink: 0;
        }

        /* --- Tables --- */
        .flex-table-container {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow: hidden;
        }

        table { width: 100%; border-collapse: collapse; font-size: var(--font-base); table-layout: fixed; line-height: 1; }
        th { background: #f0f0f0; border-bottom: 1px solid #000; padding: 1px 0; font-weight: bold; text-align: center; font-size: 6px; }
        td { border-bottom: 0.1pt solid #eee; padding: 0; vertical-align: middle; }
        
        /* Schedule Columns */
        .c-grp { width: 9px; text-align: center; font-weight: bold; font-size: 6.5px; }
        .c-date { width: 34px; color: #000; font-weight: bold; font-size: 5.2px; text-align:center; white-space: nowrap; }
        .c-ven { width: 8px; text-align: center; color: #777; font-size: 5px; }
        .c-time { width: 26px; text-align: center; font-weight: normal; font-size: 5.5px; }
        
        /* Matchup Layout */
        .c-match { text-align: center; font-size: 0; }
        .team-home { display: inline-block; width: 36%; text-align: right; font-weight: bold; font-size: 6.2px; overflow:hidden; white-space:nowrap; vertical-align: middle; }
        .team-away { display: inline-block; width: 36%; text-align: left; font-weight: bold; font-size: 6.2px; overflow:hidden; white-space:nowrap; vertical-align: middle; }
        .score-area { display: inline-block; width: 20%; text-align: center; white-space: nowrap; vertical-align: middle; }
        
        .flag-icon { width: 10px; height: 7px; display: inline-block; vertical-align: middle; border: 0.5px solid #ddd; margin: 0 1px; }
        .sb { display: inline-block; width: 6px; height: 6px; border: 0.5pt solid #444; background: #fff; margin: 0 0.5px; vertical-align: middle; }

        /* Standings Rows */
        .std-table td { border: 0.5pt solid #ddd; text-align: center; font-size: 6.8px; height: 13.5px; } 
        .std-table td:first-child { text-align: left; padding-left: 2px; font-weight: bold; width: 45%; }
        .th-A { background: var(--accent-red) !important; }
        .th-B { background: var(--accent-blue) !important; }
        .th-C { background: var(--accent-green) !important; }

        /* --- Seeding List --- */
        .seeding-content { flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        .seed-row { display: flex; align-items: flex-end; font-size: 7.5px; margin-bottom: 0px; flex-grow: 1; } 
        .seed-num { width: 12px; font-weight: bold; color: #666; }
        .seed-name { flex-grow: 1; border-bottom: 0.5pt solid #bbb; margin-right: 3px; height: 10px; }
        .seed-stat { width: 14px; border-bottom: 0.5pt solid #bbb; margin-right: 1px; height: 10px; }
        
        .vert-label {
            writing-mode: vertical-rl;
            text-orientation: mixed;
            transform: rotate(180deg);
            font-size: 4.8px;
            font-weight: bold;
            text-align: center;
            background: #f0f0f0;
            width: 10px;
            letter-spacing: 0.2px;
        }

        /* --- Cover/Back Visuals --- */
        .full-img-holder { width: 100%; height: 100%; position: relative; background: #000; overflow: hidden; }
        .full-img { width: 100%; height: 100%; object-fit: cover; }
        
        .front-overlay, .back-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            text-align: center;
            pointer-events: none;
        }
        
        .front-overlay { background: rgba(0,0,0,0.35); padding: 12px 5px 5px 5px; box-sizing: border-box; justify-content: flex-start; }
        .back-overlay { background: rgba(0,0,0,0.4); padding: 10px 5px 8px 5px; box-sizing: border-box; justify-content: flex-start; }

        .oly-logo { width: 48px; height: 24px; margin: 0 auto; }
        .oly-logo circle { fill: none; stroke-width: 3; }

        /* --- Medals Table --- */
        .medals-table { font-size: 6.5px; }
        .medals-table th { background: #222; color: #fff; font-size: 6px; height: 9px; text-align: center; }
        .medals-table td { height: 11px; border-bottom: 0.5pt solid #eee; text-align: center; }
        .medals-table tr:nth-child(even) { background: #fcfcfc; }

        /* --- PRINT SPECIFIC FIXES --- */
        @media print {
            body { background: none; margin: 0; padding: 0; }
            .print-container { width: 100%; grid-gap: 0; padding: 0; display: block; }
            .panel { margin: 0; border: 0.2pt solid #eee; float: left; page-break-inside: avoid; }
            @page { size: letter landscape; margin: 0.25in; }
        }
    </style>
</head>
